# ===== client\.env =====


# --- API Configuration ---
# The base URL for the backend API. 
# Locally, this is usually your Express server (e.g., http://localhost:3000).
# In production, this will be your Render/backend URL (e.g., https://api.yourdomain.com).
VITE_API_BASE_URL=http://host:port





# ===== client\.env.test =====


# --- API Configuration ---
# The base URL used specifically during Vitest execution.
# This ensures that component tests point to a valid (or mocked) server address.
# Sample: VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://host:port