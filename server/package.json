{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "=== CORE WORKFLOW ===": "",
    "dev": "cross-env NODE_ENV=development nodemon src/app.js",
    "start": "cross-env NODE_ENV=production node src/app.js",
    "start:watch": "cross-env NODE_ENV=production node --watch src/app.js",
    "=== TESTING ===": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:test:push": "dotenv -e .env.test -- npx prisma db push",
    "db:test:migrate": "dotenv -e .env.test -- npx prisma migrate dev",
    "db:test:generate": "dotenv -e .env.test -- npx prisma generate",
    "db:test:sync": "npm run db:test:migrate && npm run db:test:generate",
    "db:test:seed": "dotenv -e .env.test -- npx prisma db seed",
    "db:test:init": "npm run db:test:sync && npm run db:test:seed",
    "db:test:studio": "dotenv -e .env.test -- npx prisma studio",
    "db:test:reset": "dotenv -e .env.test -- npx prisma migrate reset",
    "=== INITIAL SETUP & BASELINING ===": "",
    "db:baseline": "npx prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql",
    "db:resolve": "npx prisma migrate resolve --applied 0_init",
    "db:rescue": "npm run db:baseline && npm run db:resolve",
    "=== PROTOTYPING (Experimental) ===": "",
    "db:push": "npx prisma db push",
    "=== LOCAL DEVELOPMENT WORKFLOW (Iterative) ===": "",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:sync": "npm run db:migrate && npm run db:generate",
    "db:seed": "npx prisma db seed",
    "db:init": "npm run db:sync && npm run db:seed",
    "db:studio": "npx prisma studio",
    "=== PREVIEW & PRODUCTION WORKFLOW (Safe) ===": "",
    "db:deploy": "npx prisma migrate deploy",
    "=== DRIFT RESOLUTION & REPAIR ===": "",
    "db:diff": "npx prisma migrate diff --from-schema-datamodel prisma/schema.prisma --to-schema-datasource prisma/schema.prisma --script > drift.sql",
    "db:execute": "npx prisma db execute --file ./drift.sql --schema prisma/schema.prisma",
    "db:fix": "npm run db:diff && npm run db:execute",
    "db:reset": "npx prisma migrate reset"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ejs": "^4.0.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.18.0",
    "prisma": "^7.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
